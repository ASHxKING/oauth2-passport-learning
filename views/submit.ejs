<%- include('partials/header') %>

<div class="submit-wrapper">
  <div class="submit-card">
    <h1>Share a secret</h1>
    <p class="subtitle">It's stored anonymously — no one will know it's you.</p>

    <form action="/submit" method="POST">
      <div class="form-field">
        <label for="secret">Your secret</label>
        <textarea id="secret" name="secret" placeholder="Type your secret here..." required></textarea>
      </div>
      <button type="submit" class="btn-primary">Save secret</button>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
